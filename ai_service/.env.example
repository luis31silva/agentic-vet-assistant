# === LLM Provider ===
LLM_PROVIDER=gemini
OPENAI_API_KEY=
GEMINI_API_KEY=

# === PHP Backend ===
PHP_API_URL=http://localhost:8000/api

# === OCR ===
OCR_API_URL=

# === Security ===
# Shared secret between PHP backend and AI service
AI_SERVICE_KEY=your-secret-key-here

# Comma-separated list of allowed origins (CORS)
# Use * for development, restrict in production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Host binding (use 127.0.0.1 for local-only, 0.0.0.0 for all interfaces)
BIND_HOST=127.0.0.1
BIND_PORT=9000

# === Logging ===
LOG_LEVEL=INFO
